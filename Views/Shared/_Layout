<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WisataTicketApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- ICON -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>

<div class="app-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="logo-section">
            <img src="~/images/logo.png" class="logo-img" />
        </div>

        <ul class="menu">
            <li><a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-grid"></i> Dashboard</a></li>
            <li><a asp-controller="Wisata" asp-action="Index"><i class="bi bi-map"></i> Wisata</a></li>
            <li><a asp-controller="Pengunjung" asp-action="Index"><i class="bi bi-people"></i> Pengunjung</a></li>
            <li><a asp-controller="Pemesanan" asp-action="Index"><i class="bi bi-ticket"></i> Pemesanan</a></li>
            <li><a asp-controller="Laporan" asp-action="Index"><i class="bi bi-bar-chart"></i> Laporan</a></li>
        </ul>
    </aside>

    <!-- MAIN -->
    <div class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">
            <h5 class="fw-bold m-0">Wisata Ticket Management</h5>
            <span>@DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>

        <!-- CONTENT -->
        <main class="content-area">
            @RenderBody()
        </main>

    </div>

</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
