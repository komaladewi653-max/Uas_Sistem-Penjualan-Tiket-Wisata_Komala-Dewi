using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.Rendering;
using WisataTicketApp.Models;
using WisataTicketApp.Models.ViewModels;
using WisataTicketApp.Services;


namespace WisataTicketApp.Controllers
{
    public class PemesananController : Controller
    {
        private readonly PemesananService _service;
        private readonly PengunjungService _pengunjungService;
        private readonly WisataService _wisataService;

        private readonly TicketPdfService _ticketPdfService;

        public PemesananController(
            PemesananService service,
            PengunjungService pengunjungService,
            WisataService wisataService,
            TicketPdfService ticketPdfService)
        {
            _service = service;
            _pengunjungService = pengunjungService;
            _wisataService = wisataService;
            _ticketPdfService = ticketPdfService;
        }


        public IActionResult Index()
        {
            var data = _service.GetAll();
            return View(data);
        }

        public IActionResult Create()
        {
            var vm = new PemesananViewModel();

            vm.Pengunjungs = _pengunjungService
                .GetAll()
                .Select(x => new SelectListItem
                {
                    Value = x.Id.ToString(),
                    Text = x.Nama
                })
                .ToList();

            vm.Wisatas = _wisataService
                .GetAll()
                .Select(x => new SelectListItem
                {
                    Value = x.Id.ToString(),
                    Text = x.NamaWisata
                })
                .ToList();

            return View(vm);
        }
        public IActionResult Detail(Guid id)
        {
            var data = _service.GetById(id);

            if (data == null)
                return NotFound();

            return View(data);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Create(PemesananViewModel vm)
        {
            try
            {
                var pemesanan = new Pemesanan
                {
                    PengunjungId = vm.PengunjungId,
                    WisataId = vm.WisataId,
                    JumlahTiket = vm.JumlahTiket,
                    TanggalKunjungan = vm.TanggalKunjungan
                };

                _service.Create(pemesanan);

                return RedirectToAction(nameof(Index));
            }
            catch (Exception ex)
            {
                ModelState.AddModelError("", ex.Message);

                vm.Pengunjungs = _pengunjungService
                    .GetAll()
                    .Select(x => new SelectListItem
                    {
                        Value = x.Id.ToString(),
                        Text = x.Nama
                    })
                    .ToList();

                vm.Wisatas = _wisataService
                    .GetAll()
                    .Select(x => new SelectListItem
                    {
                        Value = x.Id.ToString(),
                        Text = x.NamaWisata
                    })
                    .ToList();

                return View(vm);
            }

        }
        public IActionResult Cetak(Guid id)
        {
            var data = _service.GetById(id);

            if (data == null)
                return NotFound();

            var pdf = _ticketPdfService.Generate(data);

            return File(
                pdf,
                "application/pdf",
                $"{data.NomorTiket}.pdf");
        }
        public IActionResult Delete(Guid id)
        {
            _service.Delete(id);

            return RedirectToAction(nameof(Index));
        }
    }
}
