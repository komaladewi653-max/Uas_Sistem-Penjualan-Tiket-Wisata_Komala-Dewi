using Microsoft.AspNetCore.Mvc;
using WisataTicketApp.Models;
using WisataTicketApp.Services;

namespace WisataTicketApp.Controllers
{
    public class WisataController : Controller
    {
        private readonly WisataService _service;

        public WisataController(WisataService service)
        {
            _service = service;
        }

        public IActionResult Index()
        {
            var data = _service.GetAll();
            return View(data);
        }

        public IActionResult Create()
        {
            return View();
        }

        [HttpPost]
        public IActionResult Create(Wisata wisata)
        {
            if (!ModelState.IsValid)
                return View(wisata);

            _service.Create(wisata);

            return RedirectToAction(nameof(Index));
        }

        public IActionResult Edit(Guid id)
        {
            var wisata = _service.GetById(id);

            if (wisata == null)
                return NotFound();

            return View(wisata);
        }

        [HttpPost]
        public IActionResult Edit(Wisata wisata)
        {
            if (!ModelState.IsValid)
                return View(wisata);

            _service.Update(wisata);

            return RedirectToAction(nameof(Index));
        }

        public IActionResult Delete(Guid id)
        {
            _service.Delete(id);

            return RedirectToAction(nameof(Index));
        }
    }
}
